---
interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;
---

<nav class="text-xs text-amber-200/80 mb-6 flex flex-wrap gap-1.5 items-center font-medium" aria-label="Breadcrumb">
  <a href="/" class="hover:text-white transition-colors">Accueil</a>
  {items.map((item) => (
    <div class="flex items-center gap-1.5">
      <span class="text-amber-300/60 font-semibold font-data">/</span>
      {item.href ? (
        <a href={item.href} class="hover:text-white transition-colors">{item.label}</a>
      ) : (
        <span class="text-white font-semibold">{item.label}</span>
      )}
    </div>
  ))}
</nav>
