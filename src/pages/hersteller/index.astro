---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../site.config';
import { brands } from '../../data/brands';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Hersteller von Luft-Wasser-Wärmepumpen",
    "description": "Vergleichen Sie die besten Luft-Wasser-Wärmepumpen-Marken: Bosch, Viessmann, Vaillant, Buderus, Stiebel Eltron und Nibe.",
    "url": "https://" + siteConfig.domain + "/hersteller",
  }
];
---

<BaseLayout
  title={`Hersteller-Vergleich 2026: Die besten Wärmepumpen-Marken | ${siteConfig.name}`}
  description={`Welche Wärmepumpe ist die beste? Bosch, Viessmann, Vaillant oder Nibe? Vergleich von Preisen, Leistung, JAZ und Garantien.`}
  canonical="/hersteller"
  jsonLd={jsonLd}
>
  <section class="gradient-hero text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Hersteller", href: "/hersteller" },
      ]} />
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 font-heading mt-6">
        🏆 Wärmepumpen-Hersteller im Vergleich 2026
      </h1>
      <p class="text-green-100 text-lg max-w-2xl">
        Finden Sie die passende Luft-Wasser-Wärmepumpe für Ihr Haus. Vergleichen Sie führende Hersteller nach Effizienz (COP), Garantie und Preis.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {brands.map((b) => (
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden flex flex-col justify-between card-hover">
          <div class="p-6 space-y-4">
            <!-- Brand Badge -->
            <div class="flex justify-between items-center">
              <span class="text-xs font-semibold text-accent-500 uppercase tracking-wider bg-brand-50 px-2.5 py-1 rounded-md">
                {b.positioning}
              </span>
              <span class="text-xs font-medium text-gray-500 flex items-center gap-1">
                {b.flag} {b.country}
              </span>
            </div>

            <!-- Title -->
            <h2 class="text-2xl font-bold text-gray-900 font-heading">
              {b.name}
            </h2>

            <!-- Excerpt -->
            <p class="text-xs text-gray-600 leading-relaxed line-clamp-3">
              {b.description}
            </p>

            <!-- Metadata info -->
            <div class="bg-gray-50 p-3.5 rounded-xl text-xs space-y-1.5 border border-gray-200">
              <div class="flex justify-between">
                <span class="text-gray-500">Flaggschiff:</span>
                <span class="font-bold text-gray-800">{b.flagship}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Richtpreis (Einbau):</span>
                <span class="font-bold text-accent-500 font-data">{b.priceRange}</span>
              </div>
            </div>
          </div>

          <div class="bg-gray-50 p-5 border-t border-gray-100 flex items-center justify-between">
            <span class="text-xs text-gray-500">Garantie: {b.warranty.split(',')[0]}</span>
            <a href={`/hersteller/${b.slug}`} class="cta-gradient text-white text-xs font-bold px-4 py-2 rounded-lg shadow-sm hover:shadow-md transition-all">
              Testbericht & Infos →
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Cross-links: Guides -->
    <div class="mt-12 bg-white rounded-2xl border border-gray-200 p-6 md:p-8 shadow-sm">
      <h2 class="text-xl font-bold text-gray-900 mb-4 font-heading">📚 Relevante Ratgeber</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="/ratgeber/waermepumpe-kosten-2026" class="bg-gray-50 rounded-xl p-4 border border-gray-100 hover:border-brand-200 hover:shadow-md transition-all group">
          <span class="text-lg block mb-1">💰</span>
          <span class="font-bold text-gray-900 group-hover:text-brand-600 text-sm block">Wärmepumpen Preise 2026</span>
        </a>
        <a href="/ratgeber/waermepumpe-foerderung-2026" class="bg-gray-50 rounded-xl p-4 border border-gray-100 hover:border-brand-200 hover:shadow-md transition-all group">
          <span class="text-lg block mb-1">🏛️</span>
          <span class="font-bold text-gray-900 group-hover:text-brand-600 text-sm block">KfW-Förderung & Zuschüsse</span>
        </a>
        <a href="/ratgeber/laufende-kosten" class="bg-gray-50 rounded-xl p-4 border border-gray-100 hover:border-brand-200 hover:shadow-md transition-all group">
          <span class="text-lg block mb-1">🔌</span>
          <span class="font-bold text-gray-900 group-hover:text-brand-600 text-sm block">Laufende Stromkosten</span>
        </a>
      </div>
    </div>

    <!-- Cross-links: Rechner + FAQ -->
    <div class="mt-6 grid sm:grid-cols-2 gap-4">
      <a href="/kostenrechner" class="bg-brand-600 text-white rounded-2xl border border-brand-850 p-6 hover:bg-brand-500 transition-all group shadow-md">
        <span class="text-2xl block mb-2">🧮</span>
        <h3 class="font-bold text-lg font-heading text-accent-400 group-hover:text-accent-300">Kostenrechner</h3>
        <p class="text-xs text-green-100 mt-2">Berechnen Sie die Preise, staatliche Förderung und Ersparnis für Ihr Haus in 2 Minuten.</p>
      </a>
      <a href="/faq" class="bg-white rounded-2xl border border-gray-200 p-6 hover:border-brand-200 hover:shadow-md transition-all group">
        <span class="text-2xl block mb-2">❓</span>
        <h3 class="font-bold text-lg font-heading text-gray-900 group-hover:text-brand-600">Häufige Fragen (FAQ)</h3>
        <p class="text-xs text-gray-600 mt-2">Ausführliche Experten-Antworten zu Lärmschutz, JAZ und Altbau-Eignung.</p>
      </a>
    </div>
  </section>
</BaseLayout>
