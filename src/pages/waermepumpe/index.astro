---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../site.config';
import { getAllStates, getCitiesByState } from '../../lib/cities';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const states = getAllStates();
---

<BaseLayout
  title={`Wärmepumpen Verzeichnis — Heizungsbetriebe nach Stadt & Bundesland | ${siteConfig.name}`}
  description={`Finden Sie geprüfte Heizungsbetriebe in Ihrer Region. Unser Verzeichnis führt deutsche Städte und Gemeinden mit Kosten, Förderung und Angeboten.`}
  canonical="/waermepumpe"
>
  <section class="gradient-hero text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Städte", href: "/waermepumpe" },
      ]} />
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4 font-heading mt-6">
        📍 Wärmepumpen-Verzeichnis für Deutschland
      </h1>
      <p class="text-brand-50 text-lg">
        Wählen Sie Ihre Stadt, um regionale Angebote, Kostenberechnungen und lokale Wärmepumpen-Förderungen einzusehen.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="space-y-10">
      {states.map((state) => {
        const stateCities = getCitiesByState(state.name);
        return (
          <div id={`state-${state.name}`} class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
            <h2 class="text-xl font-bold text-gray-900 mb-1 flex items-center gap-2 font-heading border-b border-gray-100 pb-3">
              <span class="bg-brand-50 text-brand-700 px-2 py-0.5 rounded text-sm font-semibold">DE</span>
              <span>{state.name}</span>
              <span class="text-gray-400 text-sm font-normal">({stateCities.length} Städte)</span>
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 mt-4">
              {stateCities.map((city) => (
                <a
                  href={`/waermepumpe/${city.slug}`}
                  class="bg-[#FAFBFC] hover:bg-brand-50 border border-gray-200 rounded-lg px-3 py-2 hover:border-brand-200 hover:shadow-sm transition-all text-xs font-semibold text-gray-700 hover:text-brand-700"
                >
                  {city.name} ({city.zip})
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
