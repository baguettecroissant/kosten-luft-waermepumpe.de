---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteWidget from '../components/QuoteWidget.astro';
import { siteConfig } from '../../site.config';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Kostenloses Angebot für Wärmepumpen anfordern",
    "description": "Fordern Sie bis zu 3 kostenlose und unverbindliche Angebote von geprüften Heizungsbetrieben aus Ihrer Region an.",
    "url": "https://" + siteConfig.domain + "/angebot",
  }
];
---

<BaseLayout
  title={`Kostenloses Wärmepumpen-Angebot anfordern | ${siteConfig.name}`}
  description={`Vergleichen Sie Angebote von geprüften Heizungsbauern in Ihrer Region. Erhalten Sie bis zu 3 Angebote — 100% kostenlos und unverbindlich.`}
  canonical="/angebot"
  jsonLd={jsonLd}
>
  <section class="gradient-hero text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Startseite", href: "/" },
        { label: "Angebote vergleichen", href: "/angebot" },
      ]} />
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 font-heading mt-6">
        🔥 Kostenlose Wärmepumpen-Angebote vergleichen
      </h1>
      <p class="text-brand-50 text-lg max-w-xl">
        Erhalten Sie bis zu 3 Angebote von geprüften Heizungsbetrieben aus Ihrer Region. 100% kostenlos und unverbindlich.
      </p>
    </div>
  </section>

  <section class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-2">
      <QuoteWidget keyword="Wärmepumpe Angebot" />
    </div>

    <!-- Info points -->
    <div class="mt-8 grid gap-4">
      <div class="flex gap-3 bg-gray-50 p-4 rounded-xl border border-gray-200">
        <span class="text-xl">✅</span>
        <div>
          <h4 class="font-bold text-gray-900 text-sm font-heading">Geprüfte Heizungs-Fachbetriebe</h4>
          <p class="text-xs text-gray-600 mt-0.5">Alle angeschlossenen Betriebe sind qualifizierte SHK-Meisterbetriebe (Sanitär, Heizung, Klima) mit Sitz in Ihrer Region.</p>
        </div>
      </div>
      <div class="flex gap-3 bg-gray-50 p-4 rounded-xl border border-gray-200">
        <span class="text-xl">⏱️</span>
        <div>
          <h4 class="font-bold text-gray-900 text-sm font-heading">Schnelle Rückmeldung in 24-48 Std.</h4>
          <p class="text-xs text-gray-600 mt-0.5">Nach Absenden Ihrer Anfrage melden sich bis zu 3 regionale Anbieter bei Ihnen, um Ihre Heizungsmodernisierung telefonisch oder per Vor-Ort-Termin zu besprechen.</p>
        </div>
      </div>
    </div>

    <!-- Cross-links: Guides -->
    <div class="mt-10 bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
      <h3 class="text-lg font-bold text-gray-900 mb-4 font-heading">📚 Vorab-Informationen</h3>
      <div class="grid gap-3">
        <a href="/ratgeber/waermepumpe-kosten-2026" class="flex items-center gap-3 bg-gray-50 rounded-xl p-3 border border-gray-200 hover:border-brand-200 transition-all group">
          <span class="text-lg">💰</span>
          <span class="font-bold text-gray-900 group-hover:text-brand-700 text-sm font-heading">Was kostet eine Wärmepumpe 2026? — Preisübersicht</span>
        </a>
        <a href="/ratgeber/waermepumpe-foerderung-2026" class="flex items-center gap-3 bg-gray-50 rounded-xl p-3 border border-gray-200 hover:border-brand-200 transition-all group">
          <span class="text-lg">🏛️</span>
          <span class="font-bold text-gray-900 group-hover:text-brand-700 text-sm font-heading">Wärmepumpen-Förderung 2026 — KfW-Zuschüsse</span>
        </a>
        <a href="/ratgeber/luft-wasser-waermepumpe" class="flex items-center gap-3 bg-gray-50 rounded-xl p-3 border border-gray-200 hover:border-brand-200 transition-all group">
          <span class="text-lg">☘️</span>
          <span class="font-bold text-gray-900 group-hover:text-brand-700 text-sm font-heading">Luft-Wasser-Wärmepumpen — Funktion & Praxistipp</span>
        </a>
      </div>
      <div class="text-center mt-3">
        <a href="/ratgeber" class="text-brand-700 hover:text-brand-800 font-semibold text-sm transition-colors underline font-heading">Alle Ratgeber →</a>
      </div>
    </div>

    <!-- Cross-links: Hersteller + Rechner -->
    <div class="mt-6 grid sm:grid-cols-2 gap-4">
      <a href="/hersteller" class="bg-white rounded-2xl border border-gray-200 p-5 hover:border-brand-200 hover:shadow-md transition-all group">
        <span class="text-2xl block mb-2">🏆</span>
        <h4 class="font-bold text-gray-900 group-hover:text-brand-700 text-sm font-heading">Hersteller-Vergleich</h4>
        <p class="text-xs text-gray-600 mt-1">Bosch, Viessmann, Vaillant, Buderus, Nibe, Stiebel Eltron...</p>
      </a>
      <a href="/kostenrechner" class="bg-brand-900 text-white rounded-2xl border border-brand-800 p-5 hover:bg-brand-800 transition-all group shadow-md">
        <span class="text-2xl block mb-2">🧮</span>
        <h4 class="font-bold text-orange-300 group-hover:text-orange-200 text-sm font-heading">Kostenrechner</h4>
        <p class="text-xs text-brand-50 mt-1">Preise & Einsparpotenzial in 2 Minuten berechnen.</p>
      </a>
    </div>
  </section>
</BaseLayout>
